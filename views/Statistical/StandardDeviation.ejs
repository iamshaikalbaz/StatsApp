<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../Partials/Head'); %>
</head>
<body>
    
    <%- include('../Partials/Navbar'); %>
    <%- include('../Partials/Mode'); %>

    <div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-100 px-6 py-16">

    <!-- Container -->
    <div class="max-w-6xl mx-auto">

        <!-- Heading -->
        <div class="text-center mb-10">

            <h2 class="text-3xl md:text-5xl font-extrabold text-gray-800">
                Standard Deviation
            </h2>

            <p class="mt-3 text-gray-600 text-lg">
                Input class intervals and frequencies to calculate Standard Deviation
            </p>

        </div>

        <!-- Table Card -->
        <div
            class="bg-white/70 backdrop-blur-lg shadow-xl rounded-3xl overflow-hidden border border-gray-200">

            <table class="w-full text-center">

                <!-- Head -->
                <thead class="bg-gray-100/80 text-gray-700 text-lg">

                    <tr>

                        <th class="py-4">S.No</th>

                        <th class="py-4">Class Interval</th>

                        <th class="py-4">Frequency (Fi)</th>

                    </tr>

                </thead>

                <!-- Body -->
                <tbody id="table-body">

                    <tr class="border-t hover:bg-gray-50 transition">

                        <td class="py-4 font-medium">
                            1
                        </td>

                        <!-- Interval -->
                        <td class="flex justify-center items-center gap-2 py-4">

                            <input type="number" placeholder="10"
                                class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center
                                focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">

                            <span class="text-gray-500 font-semibold">–</span>

                            <input type="number" placeholder="20"
                                class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center
                                focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">

                        </td>

                        <!-- Frequency -->
                        <td>

                            <input type="number" placeholder="Fi"
                                class="w-24 px-3 py-2 rounded-xl border border-gray-300 text-center
                                focus:ring-2 focus:ring-purple-400 focus:border-purple-400 outline-none transition">

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row justify-center gap-4 mt-10">

            <!-- Add Row -->
            <button onclick="addRow()"
                class="px-6 py-3 text-lg font-semibold text-black bg-blue-200 rounded-2xl shadow-md
                hover:bg-blue-300 hover:scale-105 hover:shadow-lg transition duration-300">

                ➕ Add Row

            </button>

            <!-- Calculate -->
            <button onclick="calculate()"
                class="px-6 py-3 text-lg font-semibold text-black bg-green-200 rounded-2xl shadow-md
                hover:bg-green-300 hover:scale-105 hover:shadow-lg transition duration-300">

                📊 Calculate

            </button>

            <!-- Back -->
            <a href="/Statistical"
                class="px-6 py-3 text-lg font-semibold text-black bg-pink-200 rounded-2xl shadow-md
                hover:bg-pink-300 hover:scale-105 hover:shadow-lg transition duration-300">

                👈 Back

            </a>

        </div>

    </div>

    <!-- Result Section -->
    <div id="result-section" class="mt-12 hidden">

        <h3 class="text-2xl font-bold text-center text-gray-800 mb-6">

            Standard Deviation Table

        </h3>

        <div class="overflow-x-auto bg-white shadow-lg rounded-2xl">

            <table class="w-full text-center border">

                <thead class="bg-gray-100 text-gray-700">

                    <tr>

                        <th class="py-3 border">Xi</th>

                        <th class="border">Fi</th>

                        <th class="border">Fi × Xi</th>

                        <th class="border">Xi − X̄</th>

                        <th class="border">(Xi − X̄)²</th>

                        <th class="border">Fi(Xi − X̄)²</th>

                    </tr>

                </thead>

                <tbody id="result-body"></tbody>

            </table>

        </div>

        <!-- Formula Section -->
        <div id="formula"
            class="mt-8 bg-blue-50 p-6 rounded-2xl shadow-md text-gray-800">

        </div>

    </div>

</div>

</body>

    <script>

let count = 1;

// ➕ Add Row
function addRow() {

    count++;

    const table = document.getElementById("table-body");

    const row = `

    <tr class="border-t hover:bg-gray-50 transition">

        <td class="py-4 font-medium">
            ${count}
        </td>

        <!-- Interval -->
        <td class="flex justify-center items-center gap-2 py-4">

            <input type="number" placeholder="lower"
                class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center
                focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">

            <span class="text-gray-500 font-semibold">–</span>

            <input type="number" placeholder="upper"
                class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center
                focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">

        </td>

        <!-- Frequency -->
        <td>

            <input type="number" placeholder="Fi"
                class="w-24 px-3 py-2 rounded-xl border border-gray-300 text-center
                focus:ring-2 focus:ring-purple-400 focus:border-purple-400 outline-none transition">

        </td>

    </tr>

    `;

    table.insertAdjacentHTML("beforeend", row);

}



// 📊 Calculate Standard Deviation
function calculate() {

    const rows = document.querySelectorAll("#table-body tr");

    const resultBody = document.getElementById("result-body");

    const formulaDiv = document.getElementById("formula");

    resultBody.innerHTML = "";

    formulaDiv.innerHTML = "";

    let data = [];

    let totalFi = 0;

    let totalFixi = 0;

    // 🔹 Collect Data
    rows.forEach(row => {

        const inputs = row.querySelectorAll("input");

        const lower = parseFloat(inputs[0].value);

        const upper = parseFloat(inputs[1].value);

        const fi = parseFloat(inputs[2].value);

        if (isNaN(lower) || isNaN(upper) || isNaN(fi)) return;

        // 🔹 Xi (Mid Value)
        const xi = (lower + upper) / 2;

        // 🔹 Fi × Xi
        const fixi = fi * xi;

        totalFi += fi;

        totalFixi += fixi;

        data.push({
            lower,
            upper,
            fi,
            xi,
            fixi
        });

    });

    // 🔹 Validation
    if (data.length === 0) {

        alert("Please enter valid data!");

        return;
    }

    // 🔹 Mean
    const mean = totalFixi / totalFi;

    let totalFiSquare = 0;

    // 🔹 Build Table
    data.forEach(d => {

        // Xi - Mean
        const xiMinusMean = d.xi - mean;

        // (Xi - Mean)^2
        const square = xiMinusMean * xiMinusMean;

        // Fi(Xi - Mean)^2
        const fiSquare = d.fi * square;

        totalFiSquare += fiSquare;

        resultBody.innerHTML += `

        <tr class="border-t hover:bg-gray-50">

            <td class="border p-3">
                ${d.xi.toFixed(2)}
            </td>

            <td class="border p-3">
                ${d.fi}
            </td>

            <td class="border p-3">
                ${d.fixi.toFixed(2)}
            </td>

            <td class="border p-3">
                ${xiMinusMean.toFixed(2)}
            </td>

            <td class="border p-3">
                ${square.toFixed(2)}
            </td>

            <td class="border p-3">
                ${fiSquare.toFixed(2)}
            </td>

        </tr>

        `;

    });

    // 🔹 Total Row
    resultBody.innerHTML += `

    <tr class="bg-gray-100 font-bold">

        <td class="border p-3"></td>

        <td class="border p-3">
            N = ${totalFi}
        </td>

        <td class="border p-3">
            ${totalFixi.toFixed(2)}
        </td>

        <td class="border p-3"></td>

        <td class="border p-3"></td>

        <td class="border p-3">
            ${totalFiSquare.toFixed(2)}
        </td>

    </tr>

    `;

    // 🔹 Variance
    const variance = totalFiSquare / totalFi;

    // 🔹 Standard Deviation
    const sd = Math.sqrt(variance);

    // 🔹 Formula Section
    formulaDiv.innerHTML = `

    <div>

        <h3 class="text-3xl font-bold mb-6 text-center">
            Standard Deviation Calculation
        </h3>

        <div class="space-y-4 text-lg">

            <p>
                <b>Mean (X̄)</b> = ΣFiXi / N
            </p>

            <p>
                = ${totalFixi.toFixed(2)} / ${totalFi}
            </p>

            <p class="font-bold text-blue-600">
                Mean = ${mean.toFixed(2)}
            </p>

            <hr>

            <p>
                <b>Formula:</b>
            </p>

            <p>
                SD = √( ΣFi(Xi − X̄)² / N )
            </p>

            <p>
                = √( ${totalFiSquare.toFixed(2)} / ${totalFi} )
            </p>

            <p>
                = √(${variance.toFixed(2)})
            </p>

            <p class="text-3xl font-bold text-green-600 mt-6">
                Standard Deviation = ${sd.toFixed(2)}
            </p>

        </div>

    </div>

    `;

    // 🔹 Show Result
    document.getElementById("result-section")
        .classList.remove("hidden");

}

</script>

</html>