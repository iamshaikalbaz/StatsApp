<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../Partials/Head'); %>
</head>

<%- include('../Partials/Navbar'); %>
    <%- include('../Partials/Mode'); %>

        <body>


            <div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-100 px-6 py-16">

                <!-- Container -->
                <div class="max-w-5xl mx-auto">

                    <!-- Heading -->
                    <div class="text-center mb-10">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-gray-800">
                            Enter Grouped Data
                        </h2>
                        <p class="mt-3 text-gray-600 text-lg">
                            Input class intervals and frequencies to perform statistical calculations
                        </p>
                    </div>

                    <!-- Table Card -->
                    <div
                        class="bg-white/70 backdrop-blur-lg shadow-xl rounded-3xl overflow-hidden border border-gray-200">

                        <table class="w-full text-center">

                            <!-- Head -->
                            <thead class="bg-gray-100/80 text-gray-700 text-lg">
                                <tr>
                                    <th class="py-4">S.No</th>
                                    <th class="py-4">Class Interval</th>
                                    <th class="py-4">Frequency (f)</th>
                                </tr>
                            </thead>

                            <!-- Body -->
                            <tbody id="table-body">

                                <tr class="border-t hover:bg-gray-50 transition">
                                    <td class="py-4 font-medium">1</td>

                                    <!-- Interval -->
                                    <td class="flex justify-center items-center gap-2 py-4">
                                        <input type="number" placeholder="10" class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center 
                       focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">

                                        <span class="text-gray-500 font-semibold">–</span>

                                        <input type="number" placeholder="20" class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center 
                       focus:ring-2 focus:ring-blue-400 focus:border-blue-400 outline-none transition">
                                    </td>

                                    <!-- Frequency -->
                                    <td>
                                        <input type="number" placeholder="f" class="w-24 px-3 py-2 rounded-xl border border-gray-300 text-center 
                       focus:ring-2 focus:ring-purple-400 focus:border-purple-400 outline-none transition">
                                    </td>
                                </tr>

                            </tbody>

                        </table>
                    </div>

                    <!-- Buttons -->
                    <div class="flex flex-col sm:flex-row justify-center gap-4 mt-10">

                        <!-- Add Row -->
                        <button onclick="addRow()" class="px-6 py-3 text-lg font-semibold text-black bg-blue-200 rounded-2xl shadow-md
               hover:bg-blue-300 hover:scale-105 hover:shadow-lg
               transition duration-300">
                            ➕ Add Row
                        </button>

                        <!-- Calculate -->
                        <button onclick="calculate()" class="px-6 py-3 text-lg font-semibold text-black bg-green-200 rounded-2xl shadow-md
         hover:bg-green-300 hover:scale-105 hover:shadow-lg
         transition duration-300">
                            📊 Calculate
                        </button>

                        <a href="/Statistical" class="px-6 py-3 text-lg font-semibold text-black bg-pink-200 rounded-2xl shadow-md
         hover:bg-pink-300 hover:scale-105 hover:shadow-lg
         transition duration-300">
                            👈 Back
                    </a>

                    </div>

                </div>

                <div id="result-section" class="mt-12 hidden">

                    <h3 class="text-2xl font-bold text-center text-gray-800 mb-6">
                        Calculation Table
                    </h3>

                    <div class="overflow-x-auto bg-white shadow-lg rounded-2xl">
                        <table class="w-full text-center border">

                            <thead class="bg-gray-100 text-gray-700">
                                <tr>
                                    <th class="py-3 border">C.I</th>
                                    <th class="border">fi</th>
                                    <th class="border">C.F</th>
                                
                                </tr>
                            </thead>

                            <tbody id="result-body"></tbody>

                        </table>
                    </div>

                    <!-- Formula Section -->
                    <div id="formula" class="mt-8 bg-blue-50 p-6 rounded-2xl shadow-md text-gray-800"></div>

                </div>

              

            </div>
            </div>

            <%- include('../Partials/Footer'); %>

        </body>

        <script>
let count = 1;

// ➕ Add Row
function addRow() {
    count++;

    const table = document.getElementById("table-body");

    const row = `
    <tr class="border-t hover:bg-gray-50 transition">
      <td class="py-4 font-medium">${count}</td>

      <td class="flex justify-center items-center gap-2 py-4">
        <input type="number" placeholder="lower"
          class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center">

        <span>–</span>

        <input type="number" placeholder="upper"
          class="w-20 px-3 py-2 rounded-xl border border-gray-300 text-center">
      </td>

      <td>
        <input type="number" placeholder="f"
          class="w-24 px-3 py-2 rounded-xl border border-gray-300 text-center">
      </td>
    </tr>
  `;

    table.insertAdjacentHTML("beforeend", row);
}


// 📊 Calculate Median
function calculate() {
    const rows = document.querySelectorAll("#table-body tr");
    const resultBody = document.getElementById("result-body");
    const formulaDiv = document.getElementById("formula");

    resultBody.innerHTML = "";
    formulaDiv.innerHTML = "";

    let data = [];
    let totalF = 0;

    // 🔹 Collect Data
    rows.forEach(row => {
        const inputs = row.querySelectorAll("input");

        const lower = parseFloat(inputs[0].value);
        const upper = parseFloat(inputs[1].value);
        const f = parseFloat(inputs[2].value);

        if (isNaN(lower) || isNaN(upper) || isNaN(f)) return;

        data.push({ lower, upper, f });
        totalF += f;
    });

    if (data.length === 0) {
        alert("Please enter valid data!");
        return;
    }

    // ✅ Sort data (IMPORTANT)
    data.sort((a, b) => a.lower - b.lower);

    // 🔹 Calculate Cumulative Frequency
    let cf = 0;
    data.forEach(d => {
        cf += d.f;
        d.cf = cf;
    });

    // 🔹 Find Median Class
    const Nby2 = totalF / 2;

    let medianClass = null;

    for (let i = 0; i < data.length; i++) {
        if (data[i].cf >= Nby2) {
            medianClass = data[i];
            break;
        }
    }

    if (!medianClass) {
        alert("Unable to find median class!");
        return;
    }

    // 🔹 Values for formula
    const l = medianClass.lower;
    const f = medianClass.f;
    const h = medianClass.upper - medianClass.lower;

    const index = data.indexOf(medianClass);
    const cfPrev = index === 0 ? 0 : data[index - 1].cf;

    // 🔹 Median Calculation
    const median = l + ((Nby2 - cfPrev) / f) * h;

    // 🔹 Build Table
    data.forEach(d => {
        const isMedian = d === medianClass;

        resultBody.innerHTML += `
        <tr class="border-t ${isMedian}">
          <td class="border">${d.lower}-${d.upper}</td>
          <td class="border">${d.f}</td>
          <td class="border">${d.cf}</td>
        </tr>
        `;
    });

    // 🔹 Total Row
    resultBody.innerHTML += `
    <tr class="bg-gray-100 font-bold">
      <td class="border"></td>
      <td class="border">N = ${totalF}</td>
    
    </tr>
    `;

    // 🔹 Formula Display
    formulaDiv.innerHTML = `
<div>
  <h4 class="text-xl font-bold mb-3">Median Calculation</h4>

  <p><b>Total Frequency (N)</b> = ${totalF}</p>


  <br>

  <p><b>Median Class</b> = ${medianClass.lower} - ${medianClass.upper}</p>

  <p><b>Least Value (l)</b> = ${l}</p>
  <p><b>Frequency (f)</b> = ${f}</p>
  <p><b>Cumulative Frequency (cf)</b> = ${cfPrev}</p>
  <p><b>Class Width (h)</b> = ${h}</p>

  <br>

  <p><b>Formula:</b></p>
  <p>Median = l + ((N/2 - cf) / f) × h</p>

  <p>= ${l} + ((${Nby2} - ${cfPrev}) / ${f}) × ${h}</p>

  <p class="text-lg font-bold text-blue-600">
    = ${median.toFixed(2)}
  </p>
</div>
`;

    // Show result
    document.getElementById("result-section").classList.remove("hidden");
}
</script>

</html>