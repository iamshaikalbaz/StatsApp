<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../Partials/Head'); %>
</head>

    <%- include('../Partials/Navbar'); %>
    <%- include('../Partials/Mode'); %>

<body class="bg-gradient-to-br from-blue-50 via-white to-purple-100 min-h-screen px-6 py-16">

    <div class="max-w-7xl mx-auto">

        <!-- Heading -->
        <div class="text-center mb-10">

            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-800">
                Covariance Calculator
            </h1>

            <p class="mt-3 text-lg text-gray-600">
                Enter X and Y values to calculate Covariance step-by-step
            </p>

        </div>

        <!-- Table -->
        <div class="bg-white shadow-xl rounded-3xl overflow-hidden">

            <table class="w-full text-center">

                <thead class="bg-gray-100 text-gray-700 text-lg">

                    <tr>
                        <th class="border py-4">X</th>
                        <th class="border py-4">Y</th>
                    </tr>

                </thead>

                <tbody id="table-body">

                    <tr>

                        <td class="border p-4">
                            <input type="number"
                                class="w-28 px-3 py-2 border rounded-xl text-center"
                                placeholder="X value">
                        </td>

                        <td class="border p-4">
                            <input type="number"
                                class="w-28 px-3 py-2 border rounded-xl text-center"
                                placeholder="Y value">
                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

        <!-- Buttons -->
        <div class="flex justify-center gap-4 mt-10">

            <button onclick="addRow()"
                class="px-6 py-3 bg-blue-200 rounded-2xl font-bold hover:bg-blue-300 transition">

                ➕ Add Row

            </button>

            <button onclick="calculate()"
                class="px-6 py-3 bg-green-200 rounded-2xl font-bold hover:bg-green-300 transition">

                📊 Calculate

            </button>

             <a href="/Statistical" class="px-6 py-3 text-lg font-semibold text-black bg-pink-200 rounded-2xl shadow-md
         hover:bg-pink-300 hover:scale-105 hover:shadow-lg
         transition duration-300">
                            👈 Back
                    </a>

        </div>

        <!-- Result -->
        <div id="result-section" class="hidden mt-14">

            <h2 class="text-3xl font-bold text-center mb-6">
                Covariance Table
            </h2>

            <div class="overflow-x-auto bg-white shadow-lg rounded-2xl">

                <table class="w-full text-center border">

                    <thead class="bg-gray-100">

                        <tr>

                            <th class="border p-3">X</th>

                            <th class="border p-3">Y</th>

                            <th class="border p-3">X - X̄</th>

                            <th class="border p-3">Y - Ȳ</th>

                            <th class="border p-3">(X-X̄)(Y-Ȳ)</th>

                        </tr>

                    </thead>

                    <tbody id="result-body"></tbody>

                </table>

            </div>

            <!-- Formula Section -->
            <div id="formula"
                class="mt-8 bg-blue-50 p-8 rounded-2xl shadow-md text-gray-800">

            </div>

        </div>

    </div>


<script>

// ➕ Add Row
function addRow() {

    const table = document.getElementById("table-body");

    const row = `

    <tr>

        <td class="border p-4">
            <input type="number"
                class="w-28 px-3 py-2 border rounded-xl text-center"
                placeholder="X value">
        </td>

        <td class="border p-4">
            <input type="number"
                class="w-28 px-3 py-2 border rounded-xl text-center"
                placeholder="Y value">
        </td>

    </tr>

    `;

    table.insertAdjacentHTML("beforeend", row);

}



// 📊 Calculate Covariance
function calculate() {

    const rows = document.querySelectorAll("#table-body tr");

    const resultBody = document.getElementById("result-body");

    const formulaDiv = document.getElementById("formula");

    resultBody.innerHTML = "";

    formulaDiv.innerHTML = "";

    let data = [];

    let sumX = 0;
    let sumY = 0;

    // 🔹 Collect Data
    rows.forEach(row => {

        const inputs = row.querySelectorAll("input");

        const x = parseFloat(inputs[0].value);

        const y = parseFloat(inputs[1].value);

        if (isNaN(x) || isNaN(y)) return;

        sumX += x;
        sumY += y;

        data.push({ x, y });

    });

    // ❌ Validation
    if (data.length === 0) {

        alert("Please enter valid values!");

        return;
    }

    // 🔹 Mean
    const meanX = sumX / data.length;

    const meanY = sumY / data.length;

    let totalDX = 0;
    let totalDY = 0;
    let totalProduct = 0;

    // 🔹 Build Table
    data.forEach(d => {

        const dx = d.x - meanX;

        const dy = d.y - meanY;

        const product = dx * dy;

        totalDX += dx;
        totalDY += dy;
        totalProduct += product;

        resultBody.innerHTML += `

        <tr>

            <td class="border p-3">
                ${d.x}
            </td>

            <td class="border p-3">
                ${d.y}
            </td>

            <td class="border p-3">
                ${dx.toFixed(2)}
            </td>

            <td class="border p-3">
                ${dy.toFixed(2)}
            </td>

            <td class="border p-3">
                ${product.toFixed(2)}
            </td>

        </tr>

        `;

    });

    // 🔹 Total Row
    resultBody.innerHTML += `

    <tr class="bg-gray-100 font-bold">

        <td class="border p-3">
            ΣX = ${sumX.toFixed(2)}
        </td>

        <td class="border p-3">
            ΣY = ${sumY.toFixed(2)}
        </td>

        <td class="border p-3">
            Σ(X-X̄) = ${totalDX.toFixed(2)}
        </td>

        <td class="border p-3">
            Σ(Y-Ȳ) = ${totalDY.toFixed(2)}
        </td>

        <td class="border p-3">
            Σ[(X-X̄)(Y-Ȳ)] = ${totalProduct.toFixed(2)}
        </td>

    </tr>

    `;

    // 🔹 Covariance
    const covariance = totalProduct / data.length;

    // 🔹 Formula Section
    formulaDiv.innerHTML = `

    <div>

        <h3 class="text-3xl font-bold mb-8 text-center">
            Covariance Step-by-Step Solution
        </h3>

        <div class="space-y-5 text-lg">

            <p>
                <b>Step 1:</b> Find Mean of X
            </p>

            <p>
                X̄ = ΣX / n
            </p>

            <p>
                = ${sumX.toFixed(2)} / ${data.length}
            </p>

            <p class="font-bold text-blue-600">
                X̄ = ${meanX.toFixed(2)}
            </p>

            <hr>

            <p>
                <b>Step 2:</b> Find Mean of Y
            </p>

            <p>
                Ȳ = ΣY / n
            </p>

            <p>
                = ${sumY.toFixed(2)} / ${data.length}
            </p>

            <p class="font-bold text-blue-600">
                Ȳ = ${meanY.toFixed(2)}
            </p>

            <hr>

            <p>
                <b>Step 3:</b> Apply Covariance Formula
            </p>

            <p>
                Cov(X,Y) = Σ[(X-X̄)(Y-Ȳ)] / n
            </p>

            <p>
                = ${totalProduct.toFixed(2)} / ${data.length}
            </p>

            <p class="text-3xl font-bold text-green-600">
                Covariance = ${covariance.toFixed(2)}
            </p>

        </div>

    </div>

    `;

    // 🔹 Show Result
    document.getElementById("result-section")
        .classList.remove("hidden");

}

</script>

</body>
</html>